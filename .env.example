# PowerCodeDeck configuration
# POWERCODEDECK_* is preferred. Legacy AGENTDECK_* is still supported;
# when both are set for the same key, POWERCODEDECK_* wins.

# Authentication (default: disabled). Method: none | pin | password
POWERCODEDECK_AUTH_ENABLED=false
POWERCODEDECK_AUTH_METHOD=none

# Only used when auth is enabled:
POWERCODEDECK_PIN=
POWERCODEDECK_PASSWORD_HASH=
POWERCODEDECK_JWT_SECRET=

# Server
POWERCODEDECK_PORT=33033
# Interface to bind. 127.0.0.1 = localhost only (default, safest).
# Set 0.0.0.0 to expose on the LAN (needed for same-Wi-Fi handoff).
POWERCODEDECK_BIND_HOST=127.0.0.1
POWERCODEDECK_DB_PATH=./powercodedeck.db
POWERCODEDECK_CORS_ORIGINS=

# Default root directory for the project browser (optional)
POWERCODEDECK_WORKSPACE_ROOT=

# ── Session engine ────────────────────────────────────────
# PowerCodeDeck uses its internal PTY session engine (no tmux required).
# Per-session scrollback replay buffer (bytes) replayed on reconnect.
POWERCODEDECK_SESSION_SCROLLBACK_BYTES=524288

# ── Session Handoff (Continue on Mobile) ──────────────────
# Base URL used to build QR handoff links (recommended for public deploys).
POWERCODEDECK_PUBLIC_URL=
# Feature toggle (default: true).
POWERCODEDECK_HANDOFF_ENABLED=true
# One-time token lifetime in seconds (default: 600 = 10 minutes).
POWERCODEDECK_HANDOFF_TOKEN_TTL_SECONDS=600
# Also show a same-Wi-Fi (LAN) handoff URL. Requires BIND_HOST=0.0.0.0.
POWERCODEDECK_LAN_HANDOFF_ENABLED=false
# Explicit LAN base URL; if empty a private IPv4 is auto-detected.
POWERCODEDECK_LAN_URL=

# ── Legacy (still supported) ──────────────────────────────
# AGENTDECK_PIN=847293
# AGENTDECK_JWT_SECRET=
# AGENTDECK_PORT=33033
